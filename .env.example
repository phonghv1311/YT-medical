# ─── MySQL ───────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=secret
DB_DATABASE=telemedicine

# ─── MongoDB ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/telemedicine

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────
# Use long random strings in production (e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=2h

# ─── DigitalOcean Spaces (S3-compatible) ─────────────
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=nyc3
SPACES_BUCKET=telemedicine
SPACES_KEY=your-key
SPACES_SECRET=your-secret

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Twilio (Video / SMS) ───────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# ─── Email (SMTP) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ─── App ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ─── Support bot (optional) ───────────────────────────
# Free tier: https://console.groq.com — get API key, add below for AI replies.
# If unset, bot uses a simple keyword-based fallback.
# GROQ_API_KEY=

# ─── Frontend (Vite) ─────────────────────────────────
# Admin hotline for Emergency FAB (e.g. tel: link). Used in customer layout.
# VITE_ADMIN_HOTLINE=+1-800-123-4567
# API base URL. Leave unset when using Vite dev server (proxy forwards /api to backend).
# Set when building for production or if proxy is not used, e.g. VITE_API_URL=http://localhost:3000/api
# VITE_API_URL=
